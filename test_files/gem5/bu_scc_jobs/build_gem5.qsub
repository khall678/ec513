#!/bin/bash -l
#$ -cwd
#$ -V
#$ -j y
#$ -P ec513
#$ -N build_gem5
#$ -o logs/build_gem5.$JOB_ID.log
#$ -pe omp 16
#$ -l h_rt=04:00:00

set -euo pipefail

PROJECT_ROOT="/projectnb/ec513/students/willjdes/labs/spec-2017"
GEM5_ROOT="/projectnb/ec513/students/willjdes/labs/spec-2017/gem5"

# Load necessary modules/environment for building gem5
source "$PROJECT_ROOT/sourceme"
cd "$GEM5_ROOT"

echo "Starting gem5 build..."
# Use NSLOTS to determine how many cores Grid Engine allocated us, defaulting to 16
CORES=${NSLOTS:-16}

scons build/X86/gem5.opt -j $CORES

echo "gem5 build complete."
