#!/bin/bash -l
#$ -cwd
#$ -V
#$ -j y
#$ -P ec513
#$ -N camp_500_perlbench_r
#$ -o logs/500_perlbench_r.$JOB_ID.log
#$ -pe omp 8
#$ -l h_rt=48:00:00

set -euo pipefail

PROJECT_ROOT="/projectnb/ec513/students/willjdes/labs/spec-2017"
GEM5_ROOT="/projectnb/ec513/students/willjdes/labs/spec-2017/gem5"

source "$PROJECT_ROOT/sourceme"
cd "$GEM5_ROOT"

./run_project_benchmark.sh \
  --benchmarks 500.perlbench_r \
  --predictors LocalBP,MultiperspectivePerceptron64KB,LTAGE,MultiperspectivePerceptronTAGE64KB,CAMP \
  --camp-counter-bits 1,2,3,4 \
  --camp-window-states 1,2,4 \
  --confidence-table-sizes 4096,8192,16384 \
  --warmup-mode timing \
  --warmup-insts 1000000 \
  --measure-insts 100000000 \
  --size ref
